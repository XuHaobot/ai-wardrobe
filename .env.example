# 复制此文件为 .env 并填入真实密钥
# 此文件可安全提交到 Git（不含真实凭据）

# ====== 后端 (Python FastAPI) .env ======

# 通义千问 DashScope API Key（多模态识别/Embedding/对话/试穿）
DASHSCOPE_API_KEY=sk-your-key-here

# 高德天气 API Key（天气查询）
AMAP_API_KEY=your-amap-key-here

# 火山引擎（即梦生图 API）
VOLC_ACCESS_KEY=your-volc-ak
VOLC_SECRET_KEY=your-volc-sk
VOLC_JIMENG_MODEL=jimeng_t2i_v40

# JWT 认证
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRE_SECONDS=14400

# 数据库（本地 SQLite 即可，远程 MySQL 需替换）
DATABASE_URL=sqlite:///./data/outfit.db

# 阿里云 OSS（可选，配置后使用云存储）
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=

# 腾讯云 COS（衣物图片云端存储，可选）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma

# ====== 前端 (Vue3 + Vite) .env ======
# Vite 环境变量必须以 VITE_ 开头才能被前端访问
# 复制为 ai-outfit-recommender/.env

# 后端 API 基础路径（Vite proxy 会把 /api 转发到 8000 端口）
VITE_API_BASE=/api

# 提示：曾经有 VITE_AMAP_KEY 用于前端直连高德 IP 定位/逆地理
# 现已改造为后端代理方案（见 backend/routers/locate.py）
# 高德 API Key 仅存在于 backend/.env，前端 bundle 不会包含
