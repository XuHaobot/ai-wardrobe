# 复制此文件为 .env 并填入真实密钥
# 此文件可安全提交到 Git（不含真实凭据）

# 通义千问 DashScope API Key
DASHSCOPE_API_KEY=sk-your-key-here

# 高德天气 API Key
AMAP_API_KEY=your-amap-key-here

# 火山引擎 AK/SK（即梦生图API）
VOLC_ACCESS_KEY=your-volc-ak
VOLC_SECRET_KEY=your-volc-sk
VOLC_JIMENG_MODEL=jimeng_t2i_v40

# JWT 配置
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRE_SECONDS=14400

# 数据库（默认 SQLite，远程 MySQL 需替换）
DATABASE_URL=sqlite:///./data/outfit.db

# 阿里云 OSS（可选）
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=

# 腾讯云 COS（衣物图片云端存储，可选）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma
